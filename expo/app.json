{
  "expo": {
    "name": "Bitty",
    "slug": "bitty",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "platforms": [
      "ios"
    ],
    "newArchEnabled": true,
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "録音して文字起こしを行うためにマイクを使用します。",
          "speechRecognitionPermission": "音声を文字に変換するために音声認識を使用します。"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Cloudflare TunnelのPairing QR読み取りと顔向き判定のためにカメラを使用します。",
          "barcodeScannerEnabled": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "imageWidth": 200
        }
      ],
      "expo-font",
      "react-native-enriched-markdown",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "mode": "development"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleDevelopmentRegion": "ja",
        "CFBundleLocalizations": [
          "ja"
        ],
        "NSAlwaysAllowMicrophoneModeControl": true,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        },
        "NSLocalNetworkUsageDescription": "WebSocket接続のためにローカルネットワークを使用します。",
        "NSCameraUsageDescription": "Cloudflare TunnelのPairing QR読み取りと顔向き判定のためにカメラを使用します。",
        "NSMicrophoneUsageDescription": "録音して文字起こしを行うためにマイクを使用します。",
        "NSPhotoLibraryUsageDescription": "ワークスペースへ写真をアップロードするために写真ライブラリを使用します。",
        "NSSpeechRecognitionUsageDescription": "音声を文字に変換するために音声認識を使用します。"
      },
      "bundleIdentifier": "app.bitty.mobile",
      "entitlements": {
        "aps-environment": "development"
      }
    }
  }
}
