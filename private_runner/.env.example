# Runner bearer token used by mobile app when calling /runner-ws /codex-ws /stream-tts /stt /tts.
# Default run-local behavior is RUNNER_TOKEN_MODE=random, so this is normally generated per start
# and delivered to Expo through the pairing QR. Use RUNNER_TOKEN_MODE=env only for local debugging.
# RUNNER_TOKEN=replace-with-long-random-string
RUNNER_TOKEN_MODE=random
RUNNER_PAIRING_QR=1
RUNNER_TOKEN_FILE=private_runner/logs/runner-token
RUNNER_PUBLIC_URL=https://app.example.com

# Optional
# iOS Simulator only: 127.0.0.1 / real device access: 0.0.0.0
HOST=127.0.0.1
PORT=8788
RUNNER_MOCK=0
CODEX_HOME=$HOME/.codex
# Cloudflare Tunnel monitoring for private runner.
# Keep the real value only in local .env or Keychain-backed shell setup.
CLOUDFLARE_TUNNEL_ID=CLOUDFLARE_TUNNEL_ID
CLOUDFLARED_CONFIG_PATH=$HOME/.cloudflared/config.yml
# Cloudflare Access service token for Expo pairing QR.
# Prefer macOS Keychain services bitty-cloudflare-access-client-id and
# bitty-cloudflare-access-client-secret instead of storing real values in .env.
# CLOUDFLARE_ACCESS_CLIENT_ID=replace-with-client-id
# CLOUDFLARE_ACCESS_CLIENT_SECRET=replace-with-client-secret
# codex app-server is proxied by runner; keep it loopback unless you also configure CODEX_APP_SERVER_WS_AUTH.
CODEX_APP_SERVER_LISTEN=ws://127.0.0.1:4500
# Auth profile switching restarts run-local.sh as the same OS user by default.
# Set to 1 only if you intentionally manage both runner and codex app-server through sudo.
CODEX_AUTH_SWITCH_REQUIRE_SUDO=0
OPENAI_CODEX_MODEL=openai-codex/gpt-5.4-mini
OPENAI_CODEX_REASONING_EFFORT=low
OPENAI_CODEX_OAUTH_PROFILE=default
OPENAI_CODEX_RESPONSES_BASE_URL=https://chatgpt.com/backend-api/codex
OPENAI_CODEX_TIMEOUT_MS=86400000
MAX_TRANSCRIPT_CHARS=8000
LLM_FILE_ROOT=llm_root
LLM_FILE_MAX_READ_BYTES=65536
LLM_FILE_DEFAULT_READ_BYTES=8192
LLM_FILE_MAX_READ_LINES=400
LLM_FILE_MAX_TOOL_ROUNDS=12
LLM_FILE_ENABLE_MEDIA_TOOL=1
LLM_FILE_ENABLE_LEGACY_WRITE_TOOLS=0
LLM_FILE_AUDIT_LOG_PATH=private_runner/logs/llm_tool_audit.jsonl
LLM_REQUEST_LOG_ENABLED=1
LLM_REQUEST_LOG_DIR=private_runner/logs/llm_request_payloads
LLM_REQUEST_LOG_MAX_FILES=10
CLIENT_APP_LOG_MAX_FILES=10
# session_diag の詳細イベント保存（既定: 0=OFF）
CLIENT_APP_LOG_SESSION_DIAG_DETAIL_ENABLED=0
CODEX_WS_PROXY_DEBUG_LOG_MAX_FILES=10
# allowlist for run_command_sandboxed / run_tests
SANDBOXED_RUN_ALLOWED_COMMANDS=git,npm,pnpm,yarn,node,npx,firebase,which,pytest,go,cargo,make,ls,cat,rg,sed,awk,head,tail,wc,echo
SANDBOXED_RUN_AUTO_APPROVE_COMMANDS=which
SANDBOXED_RUN_DEFAULT_TIMEOUT_MS=86400000
SANDBOXED_RUN_MAX_TIMEOUT_MS=86400000
TOOL_APPROVAL_CACHE_MAX_SESSIONS=200
TOOL_APPROVAL_TIMEOUT_MS=86400000
RUN_TESTS_DEFAULT_TIMEOUT_MS=86400000
RUN_TESTS_MAX_TIMEOUT_MS=86400000
# RUN_TESTS_DEFAULT_COMMAND=npm test --silent
COMMAND_EXEC_BIN_DIR=private_runner/bin
COMMAND_APPROVAL_POLICY_PATH=private_runner/command_approval_policy.json
TOOLRUN_MANIFEST_PATH=private_runner/toolbox/manifest.json
# Optional for toolrun youtube_search / youtube_channel_latest / youtube_favorites
# YOUTUBE_API_KEY=replace-with-youtube-data-api-key
# Optional for youtube_favorites paging state
# YOUTUBE_FAVORITES_STATE_PATH=private_runner/logs/youtube_favorites_paging_state.json
# YOUTUBE_FAVORITES_STATE_TTL_MS=900000
# YOUTUBE_FAVORITES_PAGE_SIZE=5
# YOUTUBE_FAVORITES_TOTAL_COUNT=25
# YOUTUBE_FAVORITES_SESSION_ID=llm-session-id
# Optional for youtube_channel_latest alias extension
# YOUTUBE_CHANNEL_ALIASES_JSON={"別名":"UC...","別名2":"UC..."}
# Optional for toolrun brave_search
# BRAVE_API_KEY=replace-with-brave-search-api-key

# Optional for /stt
# GROQ_API_KEY=replace-with-groq-api-key
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
GROQ_STT_MODEL=whisper-large-v3-turbo
GROQ_STT_TIMEOUT_MS=86400000
# force STT language (ISO-639-1), default is ja
GROQ_STT_LANGUAGE=ja
MAX_AUDIO_BYTES=26214400

# Optional for /tts
# ttsProvider default (elevenlabs | google | aivisspeech)
TTS_PROVIDER=elevenlabs

# ELEVENLABS_API_KEY=replace-with-elevenlabs-api-key
ELEVENLABS_API_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Google Cloud TTS
# GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_TTS_API_BASE_URL=https://texttospeech.googleapis.com
GOOGLE_CLOUD_TTS_LANGUAGE_CODE=ja-JP
GOOGLE_CLOUD_TTS_VOICE_NAME=ja-JP-Neural2-B
GOOGLE_CLOUD_TTS_AUDIO_ENCODING=MP3

# AivisSpeech (local macOS mode only)
AIVISSPEECH_API_BASE_URL=http://127.0.0.1:10101
AIVISSPEECH_READY_TIMEOUT_MS=86400000
# AIVISSPEECH_SPEAKER=888753760

MAX_TTS_CHARS=5000
